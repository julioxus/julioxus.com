---
import { t } from '@i18n/utils';
import { certifications } from '@data/certifications';
import type { Locale } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const categoryColors: Record<string, string> = {
  offensive: 'text-red-400 bg-red-400/10 border-red-400/20',
  cloud: 'text-amber-400 bg-amber-400/10 border-amber-400/20',
  systems: 'text-blue-400 bg-blue-400/10 border-blue-400/20',
  management: 'text-purple-400 bg-purple-400/10 border-purple-400/20',
};

const categoryLabels: Record<string, Record<string, string>> = {
  offensive: { en: 'Offensive Security', es: 'Seguridad Ofensiva' },
  cloud: { en: 'Cloud', es: 'Cloud' },
  systems: { en: 'Systems', es: 'Sistemas' },
  management: { en: 'Management', es: 'Gestión' },
};
---

<section id="certifications" class="py-20 bg-bg-secondary">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">{t('certs.title', locale)}</h2>
      <p class="text-text-secondary max-w-2xl mx-auto">{t('certs.subtitle', locale)}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {certifications.map(cert => (
        <a
          href={cert.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group p-5 bg-bg-primary border border-border rounded-xl hover:border-accent/30 transition-all duration-300 animate-on-scroll"
        >
          <div class="flex items-start justify-between mb-3">
            <span class={`text-xs font-medium px-2 py-0.5 rounded-full border ${categoryColors[cert.category]}`}>
              {categoryLabels[cert.category][locale]}
            </span>
            <span class="text-xs text-text-muted">{cert.year}</span>
          </div>
          <h3 class="text-lg font-bold text-text-primary mb-1 group-hover:text-accent transition-colors">{cert.name}</h3>
          <p class="text-sm text-text-muted mb-1">{cert.fullName}</p>
          <p class="text-xs text-text-muted">{cert.issuer}</p>
          <div class="mt-3 flex items-center gap-1 text-xs text-accent opacity-0 group-hover:opacity-100 transition-opacity">
            <span>{locale === 'en' ? 'Verify' : 'Verificar'}</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
