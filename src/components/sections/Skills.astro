---
import { t } from '@i18n/utils';
import { skillCategories } from '@data/skills';
import type { Locale } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">{t('skills.title', locale)}</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skillCategories.map(category => (
        <div class="p-5 bg-bg-secondary border border-border rounded-xl animate-on-scroll">
          <h3 class="font-semibold text-text-primary mb-4 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-accent"></span>
            {t(`skills.${category.key}` as any, locale)}
          </h3>
          <div class="flex flex-wrap gap-2">
            {category.skills.map(skill => (
              <span class="px-3 py-1 text-sm bg-bg-primary border border-border rounded-lg text-text-muted hover:text-accent hover:border-accent/30 transition-colors">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
