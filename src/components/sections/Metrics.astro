---
import { t } from '@i18n/utils';
import type { Locale } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const startYear = 2015;
const yearsExp = new Date().getFullYear() - startYear;

const metrics = [
  { value: `${yearsExp}+`, key: 'metrics.years' as const, icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
  { value: '7', key: 'metrics.certs' as const, icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z' },
  { value: '5+', key: 'metrics.companies' as const, icon: 'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21' },
];
---

<section class="py-12 bg-bg-secondary border-y border-border">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-3 gap-6">
      {metrics.map(metric => (
        <div class="text-center animate-on-scroll">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-accent/10 mb-3">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={metric.icon} />
            </svg>
          </div>
          <div class="text-3xl font-bold text-text-primary mb-1">{metric.value}</div>
          <div class="text-sm text-text-muted">{t(metric.key, locale)}</div>
        </div>
      ))}
    </div>
  </div>
</section>
