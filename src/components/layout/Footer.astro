---
import { t, getLocalizedPath, getAlternateLocale } from '@i18n/utils';
import type { Locale } from '@i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const altLocale = getAlternateLocale(locale);
const altPath = getLocalizedPath('/', altLocale);
---

<footer class="border-t border-border bg-bg-secondary">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href={locale === 'en' ? '/' : '/es/'} class="text-text-primary font-bold text-xl tracking-tight">
          julioxus<span class="text-accent">.com</span>
        </a>
        <p class="mt-3 text-sm text-text-muted max-w-xs">
          {locale === 'en'
            ? 'AI-powered cybersecurity services. Penetration testing, consulting, and training.'
            : 'Servicios de ciberseguridad potenciados por IA. Pentesting, consultoría y formación.'}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-text-primary font-semibold mb-4 text-sm uppercase tracking-wider">
          {locale === 'en' ? 'Quick Links' : 'Enlaces'}
        </h3>
        <div class="flex flex-col gap-2">
          <a href="#services" class="text-sm text-text-muted hover:text-accent transition-colors">{t('nav.services', locale)}</a>
          <a href="#ai-security" class="text-sm text-text-muted hover:text-accent transition-colors">{t('nav.ai', locale)}</a>
          <a href="#about" class="text-sm text-text-muted hover:text-accent transition-colors">{t('nav.about', locale)}</a>
          <a href="#contact" class="text-sm text-text-muted hover:text-accent transition-colors">{t('nav.contact', locale)}</a>
        </div>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-text-primary font-semibold mb-4 text-sm uppercase tracking-wider">
          {locale === 'en' ? 'Connect' : 'Conectar'}
        </h3>
        <div class="flex gap-4">
          <a href="https://linkedin.com/in/julio-mart%C3%ADnez-mart%C3%ADnez-checa-91758596" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/julioxus" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
          <a href="https://app.intigriti.com/researcher/profile/julioxus" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="Intigriti">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-6h2v6zm4 0h-2v-6h2v6zm-2-8a1.5 1.5 0 110-3 1.5 1.5 0 010 3z"/></svg>
          </a>
        </div>
        <div class="mt-4">
          <a
            href={altPath}
            class="text-sm text-text-muted hover:text-accent transition-colors"
            onclick={`document.cookie='lang-pref=${altLocale};path=/;max-age=31536000;SameSite=Lax'`}
          >
            {altLocale === 'es' ? '🇪🇸 Español' : '🇬🇧 English'}
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-text-muted">
        &copy; {new Date().getFullYear()} Julio Martinez. {t('footer.rights', locale)}
      </p>
    </div>
  </div>
</footer>
